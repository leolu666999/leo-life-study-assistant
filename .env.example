# Default local-first mode. No login is required and existing local data is used.
DATA_BACKEND=sqlite
AUTH_REQUIRED=false

# Auth test mode only. Every path must be explicitly set under a system temp directory.
# TEST_DATABASE=true
# AUTH_TEST_DATA_ROOT=/tmp/myassist-auth-test
# LEO_APP_DATA_DIR=/tmp/myassist-auth-test
# LEO_DATA_DIR=/tmp/myassist-auth-test/data
# LEO_UPLOADS_DIR=/tmp/myassist-auth-test/uploads
# LEO_DB_PATH=/tmp/myassist-auth-test/data/auth-test.db
# LEO_LOG_DIR=/tmp/myassist-auth-test/logs

# Supabase public Auth configuration. These two values may be used by the browser.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only values. Never add NEXT_PUBLIC_ to either name.
# SUPABASE_SECRET_KEY=
# ADMIN_USER_ID=
