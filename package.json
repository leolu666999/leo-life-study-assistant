{
  "name": "myassist",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3011",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.cjs",
    "icon:generate": "node scripts/generate-app-icon.cjs",
    "migration:preflight": "node scripts/migration-preflight.cjs",
    "start": "next start -H 0.0.0.0 -p 3011",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "electron .",
    "desktop:pack": "npm run build && electron-builder --mac dir",
    "desktop:dist": "npm run build && electron-builder --mac dmg",
    "build:desktop": "npm run desktop:pack"
  },
  "build": {
    "appId": "com.leo.life-study-assistant",
    "productName": "MyAssist",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "!node_modules/**/*",
      "!.next/cache/**/*",
      ".next/standalone/**/*",
      "electron/**/*",
      "scripts/**/*",
      "package.json",
      "package-lock.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "dependencies": {
    "ical.js": "^2.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rrule": "^2.8.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
