{
  "name": "myassist",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3011",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.cjs",
    "icon:generate": "node scripts/generate-app-icon.cjs",
    "migration:preflight": "node scripts/migration-preflight.cjs",
    "supabase:test:provision": "node scripts/supabase-provision-test-users.cjs",
    "test:supabase:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-security.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:auth:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/auth/remote-auth.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:repositories:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-repositories.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:transactions:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-transaction-failures.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:timetable:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-timetable.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:storage:remote": "FILE_BACKEND=supabase node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-storage.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "test:phase7:remote": "node --env-file=.env.supabase-test.local ./node_modules/vitest/vitest.mjs run tests/supabase/remote-phase7.test.ts --config vitest.remote.config.ts --maxWorkers=1",
    "start": "next start -H 0.0.0.0 -p 3011",
    "test": "vitest run tests/api-contract/core-api-contract.test.ts tests/supabase/rls-security.test.ts tests/auth/data-mode-security.test.ts tests/auth/auth-boundary.test.ts tests/auth/sqlite-isolation.test.ts tests/timezone.test.ts tests/timetable-phase5.test.ts tests/timetable-month.test.ts tests/checklist-progress.test.ts tests/storage/file-security.test.ts tests/deployment/vercel-preflight.test.ts tests/phase7-product.test.ts tests/mutation-refresh.test.ts tests/schedule-entry-parser.test.ts tests/plan-search.test.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "electron .",
    "desktop:pack": "npm run build && electron-builder --mac dir",
    "desktop:dist": "npm run build && electron-builder --mac dmg",
    "build:desktop": "npm run desktop:pack"
  },
  "build": {
    "appId": "com.leo.life-study-assistant",
    "productName": "MyAssist",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "!node_modules/**/*",
      "!.next/cache/**/*",
      ".next/standalone/**/*",
      "electron/**/*",
      "scripts/**/*",
      "package.json",
      "package-lock.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}.${ext}"
    }
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "ical.js": "^2.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rrule": "^2.8.1",
    "server-only": "^0.0.1",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "supabase": "^2.109.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
